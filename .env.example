OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=99999
OLLAMA_NUM_PREDICT=1600
AI_GATEWAY_PROVIDER=ollama

# Good quality, slower on CPU/small GPUs:
# OLLAMA_MANAGER_MODEL=qwen2.5:8b
# OLLAMA_REVIEWER_MODEL=qwen3:8b
# OLLAMA_DEVELOPER_MODEL=qwen2.5-coder:7b

# Faster alternatives for a 24GB RAM / GTX 1650 machine if the above time out:
OLLAMA_MANAGER_MODEL=qwen2.5:3b
OLLAMA_REVIEWER_MODEL=qwen2.5:3b
OLLAMA_DEVELOPER_MODEL=qwen2.5-coder:3b
OLLAMA_SECURITY_MODEL=qwen2.5-coder:3b
OLLAMA_TESTING_MODEL=qwen2.5-coder:3b

# Where agent output files are written.
# Each project gets its own sub-folder: <OUTPUT_BASE_DIR>/<project_name>/
# You can also override this per-goal from the dashboard's "Output directory" field.
# Default when omitted: C:/Project
OUTPUT_BASE_DIR=C:/Project
